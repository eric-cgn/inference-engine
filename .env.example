# Docker image tag — must match the arch you built
# sm_61     → Pascal  (GTX 1050 Ti, 1060, 1070, 1080 Ti)
# sm_75plus → Turing+ (RTX 2060 and newer)
INFERENCE_IMAGE=frigate-inference:sm_61

# Absolute path to your Frigate compose file
FRIGATE_COMPOSE=/opt/frigate/compose.yaml

# Absolute path to your Frigate config directory (inference.yaml will be placed here)
FRIGATE_CONFIG_DIR=/opt/frigate/config

# Absolute path to your models directory
FRIGATE_MODELS_DIR=/opt/frigate/models
